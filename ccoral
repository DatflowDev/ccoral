#!/usr/bin/env python3
"""
CCORAL v2 — CLI
================

Usage:
    ccoral start              Start the proxy server
    ccoral run                Start proxy + launch Claude Code through it
    ccoral run --resume <n>   Resume a previous conversation through the proxy
    ccoral room <p1> <p2>     Multi-profile conversation room
    ccoral room --export last  Export conversation to markdown
    ccoral use <profile>      Set the active profile
    ccoral off                Deactivate profile (passthrough mode)
    ccoral profiles           List available profiles
    ccoral status             Show current status
    ccoral parse              Debug: dump system prompt parse tree
    ccoral log                Tail the current log
"""

import sys
import os
import subprocess
import signal
from pathlib import Path

# Add script directory to path (resolve symlinks)
SCRIPT_DIR = Path(__file__).resolve().parent
VERSION = "2.2.0"
sys.path.insert(0, str(SCRIPT_DIR))

from profiles import (
    list_profiles, load_profile, get_active_profile,
    set_active_profile, load_active_profile,
)


PORT = int(os.environ.get("CCORAL_PORT", "8080"))


def find_free_port(start=8080):
    """Find the next free port starting from start."""
    import socket
    port = start
    while port < start + 100:
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            try:
                s.bind(("127.0.0.1", port))
                return port
            except OSError:
                port += 1
    raise RuntimeError(f"No free port found in range {start}-{start+100}")


# Colors
R = "\033[31m"
G = "\033[32m"
B = "\033[34m"
Y = "\033[33m"
C = "\033[36m"
BOLD = "\033[1m"
NC = "\033[0m"


def _extract_port(argv: list[str]) -> tuple[list[str], int | None]:
    """Strip ``--port <n>`` from argv and return (argv_without_port, port_or_None).

    Used by main() to pull the top-level --port flag out before the
    per-command arg dispatch, so every subcommand can opt in uniformly.
    """
    port = None
    out: list[str] = []
    i = 0
    while i < len(argv):
        if argv[i] == "--port" and i + 1 < len(argv):
            try:
                port = int(argv[i + 1])
            except ValueError:
                print(f"{R}--port requires an integer{NC}")
                sys.exit(1)
            i += 2
            continue
        out.append(argv[i])
        i += 1
    return out, port


def cmd_start(port: int | None = None):
    """Start the proxy server.

    server.py reads CCORAL_PORT at module import time (top-level), so the
    env var MUST be set before the import to take effect.
    """
    if port is not None:
        os.environ["CCORAL_PORT"] = str(port)
    from server import main
    main()


def cmd_run(profile_name: str = None, port: int = None, resume: str = None):
    """Start proxy in background, then launch Claude through it.

    Args:
        profile_name: Lock to this profile (bypasses global active_profile)
        port: Custom port (default 8080). Use different ports for multi-instance.
        resume: Resume a previous Claude Code conversation by name.
    """
    run_port = port or find_free_port(PORT)

    # Start proxy as background process
    server_path = SCRIPT_DIR / "server.py"
    proxy_env = os.environ.copy()
    proxy_env["CCORAL_PORT"] = str(run_port)
    if profile_name:
        proxy_env["CCORAL_PROFILE"] = profile_name

    # Redirect stdout/stderr to a daily log file instead of PIPE.
    # PIPE deadlocks here: ccoral blocks in subprocess.run(claude_cmd) below,
    # so nobody drains the proxy's stdout. Once server.py fills the ~64KB pipe
    # buffer, its next write() blocks in pipe_w and every request it's
    # proxying stalls behind it.
    from datetime import datetime
    log_dir = Path.home() / ".ccoral" / "logs"
    log_dir.mkdir(parents=True, exist_ok=True)
    proxy_log_path = log_dir / f"proxy-{os.getpid()}-{datetime.now():%Y-%m-%d}.log"
    proxy_log = open(proxy_log_path, "ab", buffering=0)

    proxy = subprocess.Popen(
        [sys.executable, str(server_path)],
        stdout=proxy_log,
        stderr=subprocess.STDOUT,
        env=proxy_env,
    )

    # Give it a moment to start
    import time
    time.sleep(1)

    if proxy.poll() is not None:
        print(f"{R}Proxy failed to start (see {proxy_log_path}){NC}")
        try:
            with open(proxy_log_path, "rb") as f:
                f.seek(max(0, proxy_log_path.stat().st_size - 4096))
                print(f.read().decode(errors="replace"))
        except Exception:
            pass
        sys.exit(1)

    display_profile = profile_name or get_active_profile() or "passthrough"
    print(f"{Y}CCORAL v{VERSION}{NC} — proxy on :{run_port}, profile: {C}{display_profile}{NC}")
    if profile_name:
        print(f"  (locked to {BOLD}{profile_name}{NC} — won't read global active_profile)")
    print(f"Launching Claude Code...\n")

    # Launch Claude through the proxy
    env = os.environ.copy()
    env["ANTHROPIC_BASE_URL"] = f"http://127.0.0.1:{run_port}"

    claude_cmd = ["claude", "--dangerously-skip-permissions"]
    if resume:
        claude_cmd.extend(["--resume", resume])

    try:
        result = subprocess.run(
            claude_cmd,
            env=env,
        )
    except KeyboardInterrupt:
        pass
    finally:
        proxy.terminate()
        try:
            proxy.wait(timeout=5)
        except (KeyboardInterrupt, subprocess.TimeoutExpired):
            proxy.kill()
            proxy.wait()
        try:
            proxy_log.close()
        except Exception:
            pass
        print(f"\n{Y}CCORAL proxy stopped.{NC}")


def cmd_use(name: str, port: int | None = None):
    """Activate a profile.

    With ``port`` set, writes only the per-port file
    (``~/.ccoral/active_profile.<port>``) — leaves the global file untouched.
    Without ``port``, writes the global ``active_profile`` file.
    """
    profile = load_profile(name)
    if not profile:
        print(f"{R}Profile not found: {name}{NC}")
        print(f"Available: {', '.join(p['name'] for p in list_profiles())}")
        sys.exit(1)

    set_active_profile(name, port=port)
    scope = f"port {port}" if port is not None else "global"
    print(f"{G}Active profile: {BOLD}{name}{NC} ({scope})")
    print(f"  {profile.get('description', '')}")


def cmd_off(port: int | None = None):
    """Deactivate profile.

    With ``port`` set, removes only the per-port file. Without ``port``,
    removes the global ``active_profile`` file.
    """
    set_active_profile(None, port=port)
    scope = f"port {port}" if port is not None else "global"
    print(f"{Y}Profile deactivated — passthrough mode ({scope}){NC}")


def cmd_profiles():
    """List available profiles."""
    profiles = list_profiles()
    active = get_active_profile()

    if not profiles:
        print(f"{Y}No profiles found.{NC}")
        print(f"Add .yaml files to {Path(__file__).parent / 'profiles'}/")
        return

    print(f"\n{BOLD}Available profiles:{NC}\n")
    for p in profiles:
        marker = f"{G}▸{NC}" if p["name"] == active else " "
        print(f"  {marker} {BOLD}{p['name']}{NC}")
        if p["description"]:
            print(f"      {p['description']}")
    print()
    if active:
        print(f"  Active: {C}{active}{NC}")
    else:
        print(f"  {Y}No active profile (passthrough){NC}")
    print()


def cmd_status(port: int | None = None):
    """Show current status.

    With ``port``, resolves the active profile for that port (per-port file
    if present, else global). Without ``port``, shows the global only.
    """
    active = get_active_profile(port=port)
    profile = load_active_profile(port=port)

    print(f"\n{BOLD}CCORAL v{VERSION} Status{NC}\n")
    print(f"  Profile:  {C}{active or '(none)'}{NC}")
    if port is not None:
        # Show which file is actually winning so users can debug overrides.
        per_port_file = Path.home() / ".ccoral" / f"active_profile.{port}"
        global_file = Path.home() / ".ccoral" / "active_profile"
        if per_port_file.exists() and per_port_file.read_text().strip():
            print(f"  Source:   {per_port_file} (per-port)")
        elif global_file.exists() and global_file.read_text().strip():
            print(f"  Source:   {global_file} (global fallback)")
        else:
            print(f"  Source:   (none)")
    if profile:
        print(f"  Desc:     {profile.get('description', '')}")
        preserve = profile.get('preserve', [])
        print(f"  Preserve: {', '.join(preserve) if preserve else '(defaults)'}")
        inject_len = len(profile.get('inject', ''))
        print(f"  Inject:   {inject_len} chars")
    print(f"  Port:     {port if port is not None else PORT}")

    log_dir = Path.home() / ".ccoral" / "logs"
    if log_dir.exists():
        logs = sorted(log_dir.glob("*.jsonl"))
        if logs:
            size = logs[-1].stat().st_size
            print(f"  Log:      {logs[-1].name} ({size} bytes)")
    print()


def cmd_new(name: str):
    """Create a new profile from template."""
    profiles_dir = SCRIPT_DIR / "profiles"
    path = profiles_dir / f"{name}.yaml"

    if path.exists():
        print(f"{R}Profile already exists: {path}{NC}")
        sys.exit(1)

    template = f"""name: {name}
description: TODO — describe this profile

# What to keep from the original system prompt:
#   environment  — machine info (OS, cwd, shell)
#   hooks        — user-configured hooks
#   mcp          — tool permissions
#   claude_md    — CLAUDE.md project instructions
#   current_date — today's date
#   system       — core system section
#   all          — keep everything (passthrough)
preserve:
  - environment
  - hooks
  - mcp
  - claude_md
  - current_date

# Set minimal: true to strip EVERYTHING except what's in preserve
# minimal: true

# Your system prompt — replaces the identity and behavioral instructions:
inject: |
  You are a helpful assistant.

  TODO: Write your custom system prompt here.
"""
    path.write_text(template)
    print(f"{G}Created: {path}{NC}")
    print(f"Edit it:  {C}nvim {path}{NC}")
    print(f"Use it:   {C}ccoral use {name}{NC}")

    # Open in editor
    editor = os.environ.get("EDITOR", "nvim")
    os.execvp(editor, [editor, str(path)])


def cmd_edit(name: str):
    """Edit an existing profile."""
    profile = load_profile(name)
    if not profile:
        print(f"{R}Profile not found: {name}{NC}")
        sys.exit(1)
    editor = os.environ.get("EDITOR", "nvim")
    os.execvp(editor, [editor, profile["_path"]])


def _parse_room_args(args: list) -> dict:
    """Hand-rolled arg-walker for `ccoral room` (house style — manual parse).

    Returns a dict with keys:
      profiles, topic_parts, resume, export, export_output, legacy_cockpit,
      ls, show_id, plus all RoomConfig-bound flags:
      user, port, turn_limit, max_chars_per_turn, backpressure_turns,
      backpressure_timeout, seed1, seed2, moderator, moderator_cadence.

    Each flag uses the same `args[i+1]` peek-and-advance pattern that
    --resume / --export / --legacy-cockpit already used in this function.
    Type errors (non-int for --port, non-float for --backpressure-timeout)
    print a red one-liner and sys.exit(1) — matching the existing
    convention for malformed flags here.
    """
    out = {
        "profiles": [],
        "topic_parts": [],
        "resume": None,
        "export": None,
        "export_output": None,
        "export_format": None,
        "delete_id": None,
        "rename_from": None,
        "rename_to": None,
        "yes": False,
        "legacy_cockpit": False,
        "no_picker": False,
        "ls": False,
        "show_id": None,
        # Phase 6 sidecars.
        "watch_id": None,
        "serve_id": None,
        "serve_port": 8095,
        # RoomConfig-bound (None means "use RoomConfig default").
        "user": None,
        "port": None,
        "turn_limit": None,
        "max_chars_per_turn": None,
        "backpressure_turns": None,
        "backpressure_timeout": None,
        "seed1": None,
        "seed2": None,
        "moderator": None,
        "moderator_cadence": None,
        # Phase 5
        "resume_tail": None,
    }

    def _need_value(flag: str, peek_i: int) -> str:
        if peek_i >= len(args):
            print(f"{R}{flag} requires a value{NC}")
            sys.exit(1)
        return args[peek_i]

    def _need_int(flag: str, raw: str) -> int:
        try:
            return int(raw)
        except ValueError:
            print(f"{R}{flag} requires an integer{NC}")
            sys.exit(1)

    def _need_float(flag: str, raw: str) -> float:
        try:
            return float(raw)
        except ValueError:
            print(f"{R}{flag} requires a number{NC}")
            sys.exit(1)

    i = 0
    while i < len(args):
        a = args[i]
        if a == "--legacy-cockpit":
            out["legacy_cockpit"] = True
            i += 1
        elif a == "--no-picker":
            out["no_picker"] = True
            i += 1
        elif a == "--resume":
            out["resume"] = _need_value("--resume", i + 1)
            i += 2
        elif a == "--export":
            out["export"] = _need_value("--export", i + 1)
            i += 2
        elif a in ("--output", "-o"):
            out["export_output"] = _need_value("--output", i + 1)
            i += 2
        elif a == "--format":
            fmt = _need_value("--format", i + 1)
            if fmt not in ("md", "jsonl", "html"):
                print(f"{R}--format must be one of md|jsonl|html{NC}")
                sys.exit(1)
            out["export_format"] = fmt
            i += 2
        elif a == "--yes":
            out["yes"] = True
            i += 1
        elif a == "--user":
            out["user"] = _need_value("--user", i + 1)
            i += 2
        elif a == "--port":
            out["port"] = _need_int("--port", _need_value("--port", i + 1))
            i += 2
        elif a == "--turn-limit":
            out["turn_limit"] = _need_int(
                "--turn-limit", _need_value("--turn-limit", i + 1),
            )
            i += 2
        elif a == "--max-chars-per-turn":
            out["max_chars_per_turn"] = _need_int(
                "--max-chars-per-turn",
                _need_value("--max-chars-per-turn", i + 1),
            )
            i += 2
        elif a == "--backpressure-turns":
            out["backpressure_turns"] = _need_int(
                "--backpressure-turns",
                _need_value("--backpressure-turns", i + 1),
            )
            i += 2
        elif a == "--backpressure-timeout":
            out["backpressure_timeout"] = _need_float(
                "--backpressure-timeout",
                _need_value("--backpressure-timeout", i + 1),
            )
            i += 2
        elif a == "--seed1":
            out["seed1"] = _need_value("--seed1", i + 1)
            i += 2
        elif a == "--seed2":
            out["seed2"] = _need_value("--seed2", i + 1)
            i += 2
        elif a == "--moderator":
            out["moderator"] = _need_value("--moderator", i + 1)
            i += 2
        elif a == "--moderator-cadence":
            out["moderator_cadence"] = _need_int(
                "--moderator-cadence",
                _need_value("--moderator-cadence", i + 1),
            )
            i += 2
        elif a == "--resume-tail":
            out["resume_tail"] = _need_int(
                "--resume-tail", _need_value("--resume-tail", i + 1),
            )
            i += 2
        elif a == "ls":
            # `ccoral room ls` — list rooms. Subverb position only.
            if not out["profiles"] and not out["topic_parts"]:
                out["ls"] = True
                i += 1
                continue
            # Otherwise treat as positional (unlikely; profile named "ls").
            out["topic_parts"].append(a)
            i += 1
        elif a == "show":
            # `ccoral room show <id>` — page transcript.
            out["show_id"] = _need_value("show", i + 1)
            i += 2
        elif a == "watch":
            # `ccoral room watch <id|last>` (Phase 6 sidecar).
            out["watch_id"] = _need_value("watch", i + 1)
            i += 2
        elif a == "serve":
            # `ccoral room serve <id|last> [--port N]` (Phase 6 sidecar).
            out["serve_id"] = _need_value("serve", i + 1)
            i += 2
        elif a == "delete":
            # `ccoral room delete <id> [--yes]`
            out["delete_id"] = _need_value("delete", i + 1)
            i += 2
        elif a == "rename":
            # `ccoral room rename <id> <new-id>`
            out["rename_from"] = _need_value("rename", i + 1)
            out["rename_to"] = _need_value("rename", i + 2)
            i += 3
        elif len(out["profiles"]) < 2:
            out["profiles"].append(a)
            i += 1
        else:
            out["topic_parts"].append(a)
            i += 1

    return out


def _build_room_config(parsed: dict):
    """Promote the parsed CLI dict into a RoomConfig.

    Any flag the operator didn't pass falls through as None and the
    RoomConfig dataclass's own default takes over. Avoids the alternative
    of duplicating defaults in two places.
    """
    from room import RoomConfig
    kwargs = {}
    if parsed["user"] is not None:
        kwargs["user_name"] = parsed["user"]
    if parsed["port"] is not None:
        kwargs["base_port"] = parsed["port"]
    if parsed["turn_limit"] is not None:
        kwargs["turn_limit"] = parsed["turn_limit"]
    if parsed["max_chars_per_turn"] is not None:
        kwargs["max_chars_per_turn"] = parsed["max_chars_per_turn"]
    if parsed["backpressure_turns"] is not None:
        kwargs["backpressure_turns"] = parsed["backpressure_turns"]
    if parsed["backpressure_timeout"] is not None:
        kwargs["backpressure_timeout_s"] = parsed["backpressure_timeout"]
    # Seeds: --seed1 explicit beats positional topic; positional topic
    # promotion happens at the call site so seed2 alone (without seed1)
    # leaves seed1 free for the legacy positional.
    if parsed["seed1"] is not None:
        kwargs["seed1"] = parsed["seed1"]
    if parsed["seed2"] is not None:
        kwargs["seed2"] = parsed["seed2"]
    if parsed["moderator"] is not None:
        kwargs["moderator"] = parsed["moderator"]
    if parsed["moderator_cadence"] is not None:
        kwargs["moderator_cadence"] = parsed["moderator_cadence"]
    if parsed["resume_tail"] is not None:
        kwargs["resume_tail"] = parsed["resume_tail"]
    return RoomConfig(**kwargs)


def cmd_room(args: list):
    """Start a multi-profile conversation room.

    Phase 3: arg-walker handles --user / --port / --turn-limit /
    --max-chars-per-turn / --backpressure-turns / --backpressure-timeout /
    --seed1 / --seed2 / --moderator / --moderator-cadence in addition to
    the prior --resume / --export / --legacy-cockpit. Hand-rolled by
    house style — manual arg-walker, no stdlib parser.
    """
    from room import run_room, export_conversation

    parsed = _parse_room_args(args)

    # `ccoral room ls` — Phase 3 C5 will land the implementation; bind
    # the dispatch here so the flag is reachable from C2 onward.
    if parsed["ls"]:
        from room import room_ls
        room_ls()
        return

    # `ccoral room show <id>` — same.
    if parsed["show_id"]:
        from room import room_show
        room_show(parsed["show_id"])
        return

    # `ccoral room watch <id|last>` — Phase 6 read-only Textual tail.
    if parsed["watch_id"]:
        from room_watch import run_watch
        sys.exit(run_watch(
            parsed["watch_id"],
            user_name=parsed["user"] or "CASSIUS",
        ))

    # `ccoral room serve <id|last> [--port N]` — Phase 6 loopback aiohttp.
    if parsed["serve_id"]:
        from room_serve import run_serve
        sys.exit(run_serve(
            parsed["serve_id"],
            port=parsed["serve_port"],
            user_name=parsed["user"] or "CASSIUS",
        ))

    # `ccoral room delete <id> [--yes]`
    if parsed["delete_id"]:
        from room import delete_room
        ok = delete_room(parsed["delete_id"], yes=parsed["yes"])
        sys.exit(0 if ok else 1)

    # `ccoral room rename <id> <new-id>`
    if parsed["rename_from"]:
        from room import rename_room
        ok = rename_room(parsed["rename_from"], parsed["rename_to"])
        sys.exit(0 if ok else 1)

    if parsed["export"]:
        fmt = parsed["export_format"] or "md"
        path = export_conversation(
            parsed["export"], output=parsed["export_output"], format=fmt,
        )
        print(f"{G}Exported ({fmt}): {path}{NC}")
        return

    config = _build_room_config(parsed)

    # Legacy positional topic → seed1 unless --seed1 was explicit.
    topic = " ".join(parsed["topic_parts"]) if parsed["topic_parts"] else None
    if topic and config.seed1 is None:
        # Mutate-then-replace: dataclass instances are intentionally not
        # immutable here, but we use replace() to keep the assignment
        # explicit and audit-friendly.
        from dataclasses import replace
        config = replace(config, seed1=topic)
        topic = None  # No longer needed; seed1 carries it.

    if parsed["resume"]:
        run_room(
            parsed["profiles"][0] if parsed["profiles"] else "x",
            parsed["profiles"][1] if len(parsed["profiles"]) > 1 else "x",
            resume=parsed["resume"],
            legacy_cockpit=parsed["legacy_cockpit"],
            config=config,
        )
        return

    # Phase 10: profile picker hook. The plan (room-overhaul.md:413) lists
    # four cases; we resolve them here before the run_room call so the rest
    # of the function stays the same as Phase 3.
    #
    #   - 0 positional profiles → launch picker (unless --no-picker)
    #   - 1 positional that doesn't match a known profile → topic, picker
    #   - 2 positional that match profiles → bypass picker (current behaviour)
    #   - --no-picker with missing args → fail loudly (script-friendly)
    if len(parsed["profiles"]) < 2:
        if parsed["no_picker"]:
            print(f"{R}Usage: ccoral room <profile1> <profile2> [topic]{NC}")
            print(f"       ccoral room --resume last [--resume-tail N]")
            print(f"       ccoral room --export <last|id|filename> [--format md|jsonl|html] [--output path]")
            print(f"       ccoral room ls")
            print(f"       ccoral room show <id|last>")
            print(f"       ccoral room watch <id|last>")
            print(f"       ccoral room serve <id|last> [--port N]")
            print(f"       ccoral room delete <id|last> [--yes]")
            print(f"       ccoral room rename <id|last> <new-id>")
            sys.exit(1)

        # Single positional that doesn't name a profile → seed the picker
        # with it as the initial topic. The picker resolves the two profiles
        # and (optionally) lets the operator edit the topic before launch.
        initial_topic: str | None = None
        known_names = {p["name"] for p in list_profiles()}
        if (
            len(parsed["profiles"]) == 1
            and parsed["profiles"][0] not in known_names
        ):
            initial_topic = parsed["profiles"][0]
            parsed["profiles"] = []

        if not parsed["profiles"]:
            from room_picker import pick_profiles
            picked = pick_profiles(initial_topic=initial_topic)
            if picked is None:
                # Operator cancelled (Esc / Ctrl+C / q).
                print(f"{Y}Picker cancelled.{NC}")
                sys.exit(0)
            p1, p2, picker_topic = picked
            parsed["profiles"] = [p1, p2]
            # Picker topic overrides any earlier topic_parts only when the
            # operator typed something; empty topic from the picker leaves
            # the existing `topic` (already None at this point in the 0-
            # positional path) alone.
            if picker_topic:
                topic = picker_topic
                if config.seed1 is None:
                    from dataclasses import replace
                    config = replace(config, seed1=topic)
                    topic = None

    run_room(
        parsed["profiles"][0], parsed["profiles"][1],
        topic=topic,
        legacy_cockpit=parsed["legacy_cockpit"],
        config=config,
    )


def cmd_log():
    """Tail the log."""
    log_dir = Path.home() / ".ccoral" / "logs"
    logs = sorted(log_dir.glob("*.jsonl")) if log_dir.exists() else []
    if not logs:
        print(f"{Y}No logs yet.{NC}")
        return
    os.execvp("tail", ["tail", "-f", str(logs[-1])])


def cmd_version():
    """Print version and git commit."""
    commit = ""
    try:
        commit = subprocess.check_output(
            ["git", "rev-parse", "--short", "HEAD"],
            cwd=SCRIPT_DIR,
            stderr=subprocess.DEVNULL,
        ).decode().strip()
    except Exception:
        pass
    version_str = f"ccoral v{VERSION}"
    if commit:
        version_str += f" ({commit})"
    print(version_str)


def usage():
    print(__doc__)
    sys.exit(0)


def main():
    if len(sys.argv) < 2:
        usage()

    cmd = sys.argv[1]
    # Strip the top-level --port flag from the rest of argv before per-command
    # dispatch so every subcommand can opt in uniformly.
    argv_rest, cli_port = _extract_port(sys.argv[2:])

    if cmd == "start":
        cmd_start(port=cli_port)
    elif cmd == "run":
        run_args = list(argv_rest)
        run_resume = None
        if "--resume" in run_args:
            idx = run_args.index("--resume")
            if idx + 1 < len(run_args):
                run_resume = run_args[idx + 1]
                run_args = run_args[:idx] + run_args[idx + 2:]
            else:
                print(f"{R}--resume requires a conversation name{NC}")
                sys.exit(1)
        run_profile = run_args[0] if run_args and not run_args[0].isdigit() else None
        # Existing positional-digit port detection retained for back-compat
        # (e.g. `ccoral run vonnegut 8081`). If both --port and a positional
        # digit are supplied, the explicit --port wins.
        run_port = cli_port
        if run_port is None:
            for arg in run_args:
                if arg.isdigit():
                    run_port = int(arg)
        cmd_run(profile_name=run_profile, port=run_port, resume=run_resume)
    elif cmd == "use":
        if len(argv_rest) < 1:
            print(f"{R}Usage: ccoral use <profile> [--port <n>]{NC}")
            sys.exit(1)
        cmd_use(argv_rest[0], port=cli_port)
    elif cmd == "new":
        if len(argv_rest) < 1:
            print(f"{R}Usage: ccoral new <name>{NC}")
            sys.exit(1)
        cmd_new(argv_rest[0])
    elif cmd == "edit":
        if len(argv_rest) < 1:
            print(f"{R}Usage: ccoral edit <name>{NC}")
            sys.exit(1)
        cmd_edit(argv_rest[0])
    elif cmd == "room":
        cmd_room(argv_rest)
    elif cmd == "off":
        cmd_off(port=cli_port)
    elif cmd in ("profiles", "list", "ls"):
        cmd_profiles()
    elif cmd == "status":
        cmd_status(port=cli_port)
    elif cmd == "log":
        cmd_log()
    elif cmd in ("version", "--version", "-V"):
        cmd_version()
    elif cmd in ("-h", "--help", "help"):
        usage()
    else:
        print(f"{R}Unknown command: {cmd}{NC}")
        usage()


if __name__ == "__main__":
    main()
